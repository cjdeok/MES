{
  "version": 2,
  "builds": [
    {
      "src": "api/_handler.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/_handler.py"
    }
  ],
  "functions": {
    "api/_handler.py": {
      "maxDuration": 30,
      "includeFiles": "data/**"
    }
  }
}
